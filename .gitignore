# =========================================================================
# Pages Deployment Restrictions
# =========================================================================

# Step 1: Ignore everything inside the pages directory
src/pages/*

# Step 2: Allow the main folder structure to be scanned
!src/pages/

# Step 3: Explicitly allow ONLY these three specific page folders to be tracked
!src/pages/AddNewUser/
!src/pages/AdminDashboard/
!src/pages/AdminLogin/